<Window x:Class="BaroManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BaroManager"
        Height="720"
        Width="1200"
        MinHeight="600"
        MinWidth="950"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="BaroManager"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1"
                Padding="12"
                Margin="0,0,0,12"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="8">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                         Margin="6"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Тип:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="3"
                          ItemsSource="{Binding ItemTypes}"
                          SelectedItem="{Binding SelectedItemType}"
                          Margin="6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Путь:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding NewPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="6"/>

                <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            Margin="6">
                    <Button Content="Файл"
                            Width="80"
                            Margin="0,0,6,0"
                            Command="{Binding ChooseFileCommand}"/>
                    <Button Content="Папка"
                            Width="80"
                            Command="{Binding ChooseFolderCommand}"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Аргументы:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding NewArguments, UpdateSourceTrigger=PropertyChanged}"
                         Margin="6"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="Раб. папка:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="3"
                         Text="{Binding NewWorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Margin="6"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Теги:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1"
                         Text="{Binding NewTags, UpdateSourceTrigger=PropertyChanged}"
                         Margin="6"/>

                <StackPanel Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="6">
                    <CheckBox Content="Избранное"
                              IsChecked="{Binding NewIsFavorite}"
                              Margin="0,0,16,0"/>
                    <CheckBox Content="Запускать с менеджером"
                              IsChecked="{Binding NewRunOnAppStart}"/>
                </StackPanel>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Заметка:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="4" Grid.Column="1"
                         Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}"
                         Margin="6"/>

                <Button Grid.Row="4" Grid.Column="3"
                        Content="Добавить"
                        Height="32"
                        Margin="6"
                        Command="{Binding AddItemCommand}"/>
            </Grid>
        </Border>

<Grid Grid.Row="2">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="230"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Padding="10"
            BorderThickness="1"
            BorderBrush="#333"
            CornerRadius="8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Списки"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Height="28"
                         Text="{Binding NewCollectionName, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Название нового списка"/>

                <Button Grid.Column="1"
                        Content="Add"
                        Margin="6,0,0,0"
                        Command="{Binding AddCollectionCommand}"/>
            </Grid>

            <DockPanel Grid.Row="2">
                <Button DockPanel.Dock="Top"
                        Content="Все элементы"
                        Height="30"
                        Margin="0,0,0,8"
                        Command="{Binding ShowAllCommand}"/>

                <ListBox ItemsSource="{Binding Collections}"
                         SelectedItem="{Binding SelectedCollection}"
                         DisplayMemberPath="Name"/>
            </DockPanel>
        </Grid>
    </Border>

    <Grid Grid.Column="2">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0"
                 Height="34"
                 Margin="0,0,0,10"
                 FontSize="15"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="Поиск по названию, пути, типу, тегам и заметкам"/>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single">

            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="★"
                                        Binding="{Binding IsFavorite}"
                                        Width="40"/>

                <DataGridTextColumn Header="Тип"
                                    Binding="{Binding ItemType}"
                                    Width="90"/>

                <DataGridTextColumn Header="Название"
                                    Binding="{Binding Title}"
                                    Width="180"/>

                <DataGridTextColumn Header="Путь"
                                    Binding="{Binding Path}"
                                    Width="*"/>

                <DataGridTextColumn Header="Теги"
                                    Binding="{Binding Tags}"
                                    Width="160"/>

                <DataGridTemplateColumn Header="Действия" Width="370">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Open"
                                        Width="62"
                                        Margin="0,0,4,0"
                                        Command="{Binding DataContext.OpenItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>

                                <Button Content="Explorer"
                                        Width="72"
                                        Margin="0,0,4,0"
                                        Command="{Binding DataContext.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>

                                <Button Content="Run"
                                        Width="55"
                                        Margin="0,0,4,0"
                                        Command="{Binding DataContext.RunItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>

                                <Button Content="Copy"
                                        Width="55"
                                        Margin="0,0,4,0"
                                        Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>

                                <Button Content="Delete"
                                        Width="62"
                                        Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Grid>
</Grid>
</Window>