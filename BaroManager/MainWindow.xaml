<Window x:Class="BaroManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BaroManager"
        Height="760"
        Width="1550"
        MinHeight="650"
        MinWidth="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="BaroManager"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1"
                Padding="12"
                Margin="0,0,0,12"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="8">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Grid.ColumnSpan="4"
                           Text="{Binding FormTitleText}"
                           FontSize="17"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Название:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                         Margin="6"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Тип:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="1" Grid.Column="3"
                          ItemsSource="{Binding ItemTypes}"
                          SelectedItem="{Binding SelectedItemType}"
                          Margin="6"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Путь:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding NewPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="6"/>

                <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            Margin="6">
                    <Button Content="Файл"
                            Width="80"
                            Margin="0,0,6,0"
                            Command="{Binding ChooseFileCommand}"/>
                    <Button Content="Папка"
                            Width="80"
                            Command="{Binding ChooseFolderCommand}"/>
                </StackPanel>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Аргументы:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1"
                         Text="{Binding NewArguments, UpdateSourceTrigger=PropertyChanged}"
                         Margin="6"/>

                <TextBlock Grid.Row="3" Grid.Column="2" Text="Раб. папка:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="3"
                         Text="{Binding NewWorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Margin="6"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Теги:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="4" Grid.Column="1"
                         Text="{Binding NewTags, UpdateSourceTrigger=PropertyChanged}"
                         Margin="6"/>

                <StackPanel Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="6">
                    <CheckBox Content="Избранное"
                              IsChecked="{Binding NewIsFavorite}"
                              Margin="0,0,16,0"/>
                    <CheckBox Content="Запускать с менеджером"
                              IsChecked="{Binding NewRunOnAppStart}"/>
                </StackPanel>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Заметка:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="5" Grid.Column="1"
                         Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}"
                         Margin="6"/>

                <StackPanel Grid.Row="5"
                            Grid.Column="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="6">
                    <Button Content="{Binding MainActionText}"
                            Width="130"
                            Height="32"
                            Margin="0,0,6,0"
                            Command="{Binding AddItemCommand}"/>

                    <Button Content="Отмена"
                            Width="90"
                            Height="32"
                            Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="10"
                    BorderThickness="1"
                    BorderBrush="#333"
                    CornerRadius="8">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Списки"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="1"
                               Text="Новый список:"
                               Margin="0,0,0,4"/>

                    <Grid Grid.Row="2" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Height="28"
                                 Text="{Binding NewCollectionName, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Название нового списка"/>

                        <Button Grid.Column="1"
                                Content="Add"
                                Margin="6,0,0,0"
                                Command="{Binding AddCollectionCommand}"/>
                    </Grid>

                    <Border Grid.Row="3"
                            Padding="8"
                            Margin="0,0,0,12"
                            BorderThickness="1"
                            BorderBrush="#444"
                            CornerRadius="6">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Выбранный список:"
                                       FontWeight="Bold"
                                       Margin="0,0,0,6"/>

                            <TextBox Grid.Row="1"
                                     Height="28"
                                     Text="{Binding SelectedCollectionName, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Название выбранного списка"/>

                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        Margin="0,8,0,0">
                                <Button Content="Rename"
                                        Width="90"
                                        Margin="0,0,6,0"
                                        Command="{Binding RenameSelectedCollectionCommand}"/>

                                <Button Content="Delete"
                                        Width="80"
                                        Command="{Binding DeleteSelectedCollectionCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DockPanel Grid.Row="4">
                        <Button DockPanel.Dock="Top"
                                Content="Все элементы"
                                Height="30"
                                Margin="0,0,0,8"
                                Command="{Binding ShowAllCommand}"/>

                        <ListBox ItemsSource="{Binding Collections}"
                                 SelectedItem="{Binding SelectedCollection}"
                                 DisplayMemberPath="DisplayName"/>
                    </DockPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="125"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Height="34"
                             FontSize="15"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Поиск по названию, пути, типу, статусу, тегам и заметкам"/>

                    <CheckBox Grid.Column="1"
                              Content="Only missing"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              IsChecked="{Binding ShowOnlyMissing}"/>

                    <Button Grid.Column="2"
                            Content="Check paths"
                            Height="34"
                            Margin="6,0,0,0"
                            Command="{Binding CheckPathsCommand}"/>

                    <TextBlock Grid.Column="3"
                               Text="Целевой список:"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="0,0,8,0"/>

                    <ComboBox Grid.Column="4"
                              Height="34"
                              ItemsSource="{Binding Collections}"
                              SelectedItem="{Binding SelectedTargetCollection}"
                              DisplayMemberPath="DisplayName"/>
                </Grid>

                <TextBlock Grid.Row="1"
                           Margin="0,0,0,8"
                           Foreground="#777"
                           Text="Check paths проверяет, существуют ли сохранённые пути. Recovery через Everything добавим позже."/>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          RowHeight="30"
                          FontSize="13">

                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="★"
                                                Binding="{Binding IsFavorite}"
                                                Width="40"/>

                        <DataGridTextColumn Header="Статус"
                                            Binding="{Binding StatusDisplay}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Тип"
                                            Binding="{Binding TypeDisplay}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Название"
                                            Binding="{Binding Title}"
                                            Width="170"/>

                        <DataGridTextColumn Header="Путь"
                                            Binding="{Binding Path}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Теги"
                                            Binding="{Binding Tags}"
                                            Width="140"/>

                        <DataGridTemplateColumn Header="Действия" Width="720">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Open"
                                                Width="58"
                                                Margin="0,0,4,0"
                                                Command="{Binding DataContext.OpenItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>

                                        <Button Content="Explorer"
                                                Width="72"
                                                Margin="0,0,4,0"
                                                Command="{Binding DataContext.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>

                                        <Button Content="Run"
                                                Width="50"
                                                Margin="0,0,4,0"
                                                Command="{Binding DataContext.RunItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>

                                        <Button Content="Copy"
                                                Width="52"
                                                Margin="0,0,4,0"
                                                Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>

                                        <Button Content="Edit"
                                                Width="50"
                                                Margin="0,0,4,0"
                                                Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>

                                        <Button Content="Add to list"
                                                Width="82"
                                                Margin="0,0,4,0"
                                                ToolTip="Добавить элемент в целевой список"
                                                Command="{Binding DataContext.AddToTargetListCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>

                                        <Button Content="Move to list"
                                                Width="88"
                                                Margin="0,0,4,0"
                                                ToolTip="Перенести из текущего списка в целевой"
                                                Command="{Binding DataContext.MoveToTargetListCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>

                                        <Button Content="Remove"
                                                Width="70"
                                                Margin="0,0,4,0"
                                                ToolTip="Убрать только из выбранного списка"
                                                Command="{Binding DataContext.RemoveFromCurrentListCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>

                                        <Button Content="Delete All"
                                                Width="78"
                                                ToolTip="Удалить элемент из менеджера полностью"
                                                Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>