                    <DataGrid.ContextMenu>
    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
        <MenuItem Header="Открыть"
                  Command="{Binding OpenItemCommand}"
                  CommandParameter="{Binding SelectedItem}"
                  IsEnabled="{Binding HasSelectedItem}"/>

        <MenuItem Header="Показать в проводнике"
                  Command="{Binding OpenInExplorerCommand}"
                  CommandParameter="{Binding SelectedItem}"
                  IsEnabled="{Binding HasSelectedItem}"/>

        <MenuItem Header="Запустить"
                  Command="{Binding RunItemCommand}"
                  CommandParameter="{Binding SelectedItem}"
                  IsEnabled="{Binding HasSelectedItem}"/>

        <Separator/>

        <MenuItem Header="Копировать путь"
                  Command="{Binding CopyPathCommand}"
                  CommandParameter="{Binding SelectedItem}"
                  IsEnabled="{Binding HasSelectedItem}"/>

        <MenuItem Header="Редактировать"
                  Command="{Binding EditItemCommand}"
                  CommandParameter="{Binding SelectedItem}"
                  IsEnabled="{Binding HasSelectedItem}"/>

        <Separator/>

        <MenuItem Header="Найти переехавший файл"
                  Command="{Binding FindMovedSelectedItemCommand}"
                  IsEnabled="{Binding HasSelectedItem}"/>

        <MenuItem Header="Взять выбранный путь из Everything"
                  Command="{Binding UpdateSelectedItemPathFromEverythingCommand}"
                  IsEnabled="{Binding CanUseEverythingPath}"/>

        <Separator/>

        <MenuItem Header="Убрать из текущего списка"
                  Command="{Binding RemoveFromCurrentListCommand}"
                  CommandParameter="{Binding SelectedItem}"
                  IsEnabled="{Binding HasSelectedItem}"/>

        <MenuItem Header="Удалить полностью"
                  Command="{Binding DeleteItemCommand}"
                  CommandParameter="{Binding SelectedItem}"
                  IsEnabled="{Binding HasSelectedItem}"/>
    </ContextMenu>
</DataGrid.ContextMenu>

