    <Border Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource InputBorder}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="10"
            Margin="0,8,0,0">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="170"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Height="32"
                         Text="{Binding EverythingQuery, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Everything search query"/>

                <TextBox Grid.Column="1"
                         Height="32"
                         Margin="6,0,0,0"
                         Text="{Binding EverythingMaxResults, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Max results"/>

                <Button Grid.Column="2"
                        Content="Открыть"
                        Height="32"
                        Margin="6,0,0,0"
                        Command="{Binding SearchEverythingCommand}"/>

                <Button Grid.Column="3"
                        Content="Найти"
                        Height="32"
                        Margin="6,0,0,0"
                        Command="{Binding OpenEverythingResultCommand}"
                        IsEnabled="{Binding HasSelectedEverythingResult}"
                        CommandParameter="{Binding SelectedEverythingResult}"/>

                <Button Grid.Column="4"
                        Content="Проводник"
                        Height="32"
                        Margin="6,0,0,0"
                        Command="{Binding OpenEverythingResultInExplorerCommand}"
                        IsEnabled="{Binding HasSelectedEverythingResult}"
                        CommandParameter="{Binding SelectedEverythingResult}"/>

                <Button Grid.Column="5"
                        Content="Копировать"
                        Height="32"
                        Margin="6,0,0,0"
                        Command="{Binding CopyEverythingResultPathCommand}"
                        IsEnabled="{Binding HasSelectedEverythingResult}"
                        CommandParameter="{Binding SelectedEverythingResult}"/>

                <Button Grid.Column="6"
                        Content="Добавить"
                        Height="32"
                        Margin="6,0,0,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding AddEverythingResultCommand}"
                        IsEnabled="{Binding HasSelectedEverythingResult}"
                        CommandParameter="{Binding SelectedEverythingResult}"/>
            </Grid>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding EverythingResults}"
                      SelectedItem="{Binding SelectedEverythingResult}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      RowHeight="28"
                      FontSize="12">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Тип"
                                        Binding="{Binding TypeDisplay}"
                                        Width="110"/>

                    <DataGridTextColumn Header="Имя"
                                        Binding="{Binding Name}"
                                        Width="220"/>

                    <DataGridTextColumn Header="Путь"
                                        Binding="{Binding Path}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</Expander>

                <DataGrid x:Name="MainItemsGrid"
